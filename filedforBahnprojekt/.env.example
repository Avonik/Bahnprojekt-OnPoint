TRAINDB_HOST=localhost
TRAINDB_PORT=3306
TRAINDB_USER=bahnapp
TRAINDB_PASSWORD=change-me
TRAINDB_DATABASE=TrainDB

ROUTING_PROVIDER=auto
TRANSPORT_REST_BASE_URL=https://v6.db.transport.rest
# auto prefers the package-provided Bun runtime; set an explicit path to override it.
NODE_EXECUTABLE=auto
DB_ROUTE_USER_AGENT=OnPoint Bahnprojekt/1.0 (https://bahn.juhermes.de; https://juhermes.de)
DBNAV_USER_AGENT=OnPoint Bahnprojekt/1.0 (https://bahn.juhermes.de; https://juhermes.de)
DBWEB_USER_AGENT=Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
STATION_BOARD_PROFILE=dbweb
STATION_BOARD_USER_AGENT=OnPoint Bahnprojekt/1.0 (https://bahn.juhermes.de; https://juhermes.de)
# Required only when STATION_BOARD_PROFILE=dbris.
DB_CLIENT_ID=
DB_API_KEY=
TRANSFER_COMFORT_PENALTY_MINUTES=5
DEFAULT_FALLBACK_DELAY_MINUTES=120
